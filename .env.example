# ─── Required: At least one LLM API key ─────────────────────────────────────
# OPENAI_API_KEY is required for the agent to load. Without it, the server
# will still serve the frontend but agent/AI features will be unavailable.
# The /health endpoint will report agent_loaded=false until a valid key is set.
OPENAI_API_KEY=your-openai-api-key-here
# ANTHROPIC_API_KEY=your-anthropic-api-key-here
# GOOGLE_API_KEY=your-google-api-key-here

# ─── Optional: Agent model (default: openai:gpt-4o-mini) ────────────────────
# AGENT_MODEL=openai:gpt-4o-mini

# ─── Optional: Server configuration ─────────────────────────────────────────
# PORT=5000
# PYTHON_ENV=production
# ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com
# WEB_CONCURRENCY=2

# ─── Optional: Disable live agent deployment from frontend ───────────────────
# DEPLOY_AGENT_ENABLED=false

# ─── Optional: LangSmith tracing ────────────────────────────────────────────
# LANGCHAIN_TRACING_V2=true
# LANGCHAIN_API_KEY=your-langsmith-api-key-here
# LANGCHAIN_PROJECT=my-project

# ─── Running the server ─────────────────────────────────────────────────────
# 1. Copy this file to .env:  cp .env.example .env
# 2. Replace OPENAI_API_KEY with your actual key
# 3. Run: python server.py
# The server starts on port 5000 by default (set PORT to change)
