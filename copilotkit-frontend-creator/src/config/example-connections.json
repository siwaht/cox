{
  "connections": [
    {
      "name": "Local LangGraph",
      "frontend": "copilotkit",
      "runtime": "langgraph",
      "baseUrl": "http://localhost:2024",
      "agentId": "agent",
      "auth": { "mode": "none" }
    },
    {
      "name": "Local LangChain",
      "frontend": "copilotkit",
      "runtime": "langchain",
      "baseUrl": "http://localhost:8000",
      "auth": { "mode": "none" }
    },
    {
      "name": "Remote Deep Agent",
      "frontend": "copilotkit",
      "runtime": "deepagents",
      "baseUrl": "https://agent.example.com",
      "agentId": "deep-agent",
      "auth": { "mode": "bearer", "tokenEnv": "AGENT_API_TOKEN" }
    },
    {
      "name": "Tambo + LangChain Backend",
      "frontend": "tambo",
      "runtime": "langchain",
      "baseUrl": "http://localhost:8000",
      "auth": { "mode": "none" },
      "env": {
        "TAMBO_API_KEY": "",
        "TAMBO_URL": "https://api.tambo.co"
      }
    }
  ],
  "frontend": {
    "template": "default-agent-workspace",
    "blocks": ["chat", "results", "toolActivity", "approvals", "logs"],
    "fallbackMode": "generic-copilotkit-workspace"
  }
}
